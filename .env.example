# MultiPortal Listing Manager — Environment Variables
# Copy this file to .env and fill in values for local development.
# Do not commit .env to version control.
# All variables are required at startup unless marked (optional).

# ---- Docker Compose ----
POSTGRES_USER=your-db-username
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=multiportal
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=your-minio-user
MINIO_ROOT_PASSWORD=your-minio-password
# (optional) Docker image tags — defaults are set in docker-compose.yml
# POSTGRES_IMAGE=postgres:18.4-alpine3.23
# REDIS_IMAGE=redis:8.8.0-alpine3.23
# MINIO_IMAGE=minio/minio:RELEASE.2025-07-23T15-54-02Z

# ---- Database ----
DATABASE_URL=postgresql://your-user:your-password@localhost:5432/your-database

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- S3 / MinIO ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_FORCE_PATH_STYLE=true

# ---- Authentication ----
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars
SESSION_SECRET=replace-with-a-random-secret-at-least-32-chars
CSRF_SECRET=replace-with-a-random-secret-at-least-32-chars
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=120
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=300000
AUTH_LOGIN_RATE_LIMIT_MAX_REQUESTS=10
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=3600000
AUTH_REGISTER_RATE_LIMIT_MAX_REQUESTS=5
AUTH_FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=3600000
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX_REQUESTS=5
AUTH_RESET_PASSWORD_RATE_LIMIT_WINDOW_MS=3600000
AUTH_RESET_PASSWORD_RATE_LIMIT_MAX_REQUESTS=10
AUTH_ACTIVATE_RATE_LIMIT_WINDOW_MS=900000
AUTH_ACTIVATE_RATE_LIMIT_MAX_REQUESTS=30
AUTH_PASSWORD_RESET_RESEND_COOLDOWN_MS=300000
# ---- Resource and publication limits ----
# Total size is tracked from server-recorded listing media. Every upload must belong to a listing.
USER_STORAGE_QUOTA_BYTES=536870912
USER_MAX_LISTINGS=1000
USER_MAX_ACTIVE_PUBLICATION_JOBS=25
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
PUBLICATION_RATE_LIMIT_WINDOW_MS=60000
PUBLICATION_RATE_LIMIT_MAX_REQUESTS=10
WORKER_PUBLICATION_CONCURRENCY=2
WORKER_PUBLICATION_MAX_JOBS_PER_MINUTE=30
# Passwords are checked through HIBP's k-anonymity range API; only a SHA-1 hash prefix is sent.
PASSWORD_BREACH_CHECK_ENABLED=true
PASSWORD_BREACH_CHECK_FAIL_CLOSED=true
PASSWORD_BREACH_CHECK_URL=https://api.pwnedpasswords.com/range/
PASSWORD_BREACH_CHECK_TIMEOUT_MS=3000

# ---- Token Encryption (32-byte hex string for AES-256-GCM) ----
TOKEN_ENCRYPTION_KEY=replace-with-a-64-character-hex-string

# ---- Application ----
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
LOG_LEVEL=debug
API_PROXY_URL=http://localhost:3001
# Optional: set these when the app is exposed behind a public domain / reverse proxy
# API_PUBLIC_URL=https://api.example.com
# WEB_PUBLIC_URL=https://app.example.com
# Optional: used by the Next.js scaffold under apps/web/src/
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# ---- SMTP / Email ----
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@manager.multiportal.site
SMTP_FROM_NAME=MultiPortal
# Optional: set to false only when your SMTP relay explicitly allows non-TLS SMTP on the chosen port
# SMTP_REQUIRE_TLS=true
# Optional: set to true only for temporary local debugging against a broken SMTP certificate chain
# Never enable this in production.
# SMTP_TLS_ALLOW_INVALID_CERTS=false
# Optional: use when replies should go elsewhere than the sender mailbox
# SMTP_REPLY_TO=noreply@manager.multiportal.site
# Optional: use when your SMTP relay requires an explicit sender mailbox
# SMTP_SENDER=noreply@manager.multiportal.site

# ---- Provider OAuth App Registration (future) ----
# These are the application's own OAuth client credentials,
# registered with each marketplace provider (like a GitHub OAuth App).
# Individual users connect their own marketplace accounts through the web UI
# OAuth flow — their per-user tokens are stored encrypted in the database,
# not in this file.
# Leave empty until official API access is obtained.
# OLX_CLIENT_ID=
# OLX_CLIENT_SECRET=
# OLX_CALLBACK_URL=
# VINTED_CLIENT_ID=
# VINTED_CLIENT_SECRET=
# VINTED_CALLBACK_URL=
# FACEBOOK_MARKETPLACE_CLIENT_ID=
# FACEBOOK_MARKETPLACE_CLIENT_SECRET=
# FACEBOOK_MARKETPLACE_CALLBACK_URL=
