{
  "name": "@multiportal/worker",
  "version": "0.4.17",
  "private": true,
  "description": "MultiPortal Listing Manager background worker (BullMQ)",
  "scripts": {
    "dev": "node --watch worker.js",
    "start": "node worker.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json && node --check worker.js && node --check healthcheck.js && node --check runtime-config.js",
    "test": "pnpm run lint",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@multiportal/config": "workspace:*",
    "@multiportal/connectors": "workspace:*",
    "@multiportal/shared": "workspace:*",
    "bullmq": "^5.80.1",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.0"
  }
}
