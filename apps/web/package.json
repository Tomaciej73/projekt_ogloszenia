{
  "name": "@multiportal/web",
  "version": "0.4.0",
  "private": true,
  "description": "MultiPortal Listing Manager web frontend (Next.js)",
  "scripts": {
    "dev": "node --watch front-server.js",
    "dev:next": "next dev",
    "start": "node front-server.js",
    "build": "next build",
    "lint": "tsc --noEmit -p tsconfig.json && node --check front-server.js && node --check runtime-config.js",
    "test": "pnpm run lint",
    "clean": "rm -rf .next dist"
  },
  "dependencies": {
    "@multiportal/shared": "workspace:*",
    "@shadcn/ui": "^0.0.4",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
