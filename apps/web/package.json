{
  "name": "@multiportal/web",
  "version": "0.4.12",
  "private": true,
  "description": "MultiPortal Listing Manager web frontend (Next.js)",
  "scripts": {
    "dev": "node --watch front-server.js",
    "dev:next": "next dev",
    "start": "node front-server.js",
    "build": "next build",
    "lint": "tsc --noEmit -p tsconfig.json && node --check front-server.js && node --check healthcheck.js && node --check runtime-config.js",
    "test": "pnpm run lint && node --test auth-form-security.test.js account-panel.test.js listings-feedback.test.js",
    "clean": "rm -rf .next dist"
  },
  "dependencies": {
    "@multiportal/config": "workspace:*",
    "@multiportal/shared": "workspace:*",
    "@shadcn/ui": "^0.0.4",
    "dotenv": "^17.4.2",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
