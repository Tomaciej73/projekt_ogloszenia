{
  "name": "@multiportal/api",
  "version": "0.4.9",
  "private": true,
  "description": "MultiPortal Listing Manager REST API (NestJS)",
  "scripts": {
    "dev": "node --watch db-server.js",
    "dev:nest": "nest start --watch",
    "start": "node db-server.js",
    "build": "nest build",
    "lint": "tsc --noEmit -p tsconfig.json && node --check db-server.js && node --check healthcheck.js && node --check mail.js && node --check marketplace-account-response.js && node --check media-access.js && node --check minio.js && node --check password-security.js && node --check runtime-config.js",
    "test": "pnpm run lint && node --test marketplace-account-response.test.js media-access.test.js password-security.test.js mail-template.test.js audit-metadata.test.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@multiportal/config": "workspace:*",
    "@multiportal/connectors": "workspace:*",
    "@multiportal/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.80.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/node": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0"
  }
}
