FROM node:24.18.0-alpine

WORKDIR /app

# Install all runtime dependencies
RUN npm install dotenv pg @prisma/client @prisma/adapter-pg prisma jsonwebtoken bullmq minio nodemailer

# Copy application source
COPY apps/api/db-server.js apps/api/
COPY apps/api/minio.js apps/api/
COPY apps/api/mail.js apps/api/
COPY apps/api/prisma/ apps/api/prisma/
COPY packages/ packages/
COPY prisma.config.ts prisma.config.ts

# Generate Prisma client
RUN npx prisma generate --schema=apps/api/prisma/schema.prisma

EXPOSE 3001

CMD ["node", "apps/api/db-server.js"]